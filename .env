# ================================
# 通用配置
# ================================

# 调试模式（true/false）
# 设置为 true 时，会保存提取的数据到 debug_data/ 目录
DEBUG=false

# ================================
# 飞书webhook配置
# ================================
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/1a27225a-e75b-4e84-a3b5-4ed005d98dae
FEISHU_SIGN_SECRET=BD1a3UcRbKlUurn0KqQYGg

# 服务配置
HOST=0.0.0.0
PORT=9100

# Streamlit 前端配置（生产环境改为实际域名）
API_BASE_URL=http://localhost:9100

# 小红书轮询任务配置（分钟）
XHS_POLL_INTERVAL_MINUTES=30  # 小红书轮询间隔时间（默认30分钟）
XHS_POLL_DURATION_MINUTES=60  # 小红书任务总时长（默认60分钟）
XHS_MAX_RETRIES=3  # 小红书任务最大重试次数（默认3次）

# TikTok 轮询任务配置（分钟）
TIKTOK_POLL_INTERVAL_MINUTES=30  # TikTok轮询间隔时间（默认30分钟）
TIKTOK_POLL_DURATION_MINUTES=60  # TikTok任务总时长（默认60分钟）
TIKTOK_MAX_RETRIES=3  # TikTok任务最大重试次数（默认3次）

# 小红书 Cookie 配置（JSON 格式）
XHS_COOKIE=
# TikTok Cookie 配置（JSON 格式）
# 格式：[{"name": "cookie_name", "value": "cookie_value", "domain": ".tiktok.com", "path": "/"}]
TIKTOK_COOKIE=

# Playwright 浏览器代理配置
# 如果需要为 TikTok 使用代理，填写代理地址（HTTP/SOCKS5）
# 格式：http://host:port 或 socks5://host:port
PLAYWRIGHT_PROXY=socks5://172.25.4.8:10404
