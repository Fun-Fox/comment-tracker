# ================================
# 通用配置
# ================================

# 调试模式（true/false）
# 设置为 true 时，会保存提取的数据到 debug_data/ 目录
DEBUG=false

# ================================
# 飞书webhook配置
# ================================
FEISHU_WEBHOOK_URL=
FEISHU_SIGN_SECRET=

# 服务配置
HOST=0.0.0.0
PORT=9100

# Streamlit 前端配置
API_BASE_URL=http://localhost:9100

# 小红书轮询任务配置（分钟）
XHS_POLL_INTERVAL_MINUTES=1
XHS_POLL_DURATION_MINUTES=60
XHS_MAX_RETRIES=3

# TikTok 轮询任务配置（分钟）
TIKTOK_POLL_INTERVAL_MINUTES=1
TIKTOK_POLL_DURATION_MINUTES=60
TIKTOK_MAX_RETRIES=3

# 小红书 Cookie 配置（JSON 格式）
XHS_COOKIE=

# TikTok Cookie 配置（JSON 格式）
# 格式：[{"name": "cookie_name", "value": "cookie_value", "domain": ".tiktok.com", "path": "/"}]
TIKTOK_COOKIE=

# Playwright 浏览器代理配置
# 如果需要为 TikTok 使用代理，填写代理地址（HTTP/SOCKS5）
# 格式：http://host:port 或 socks5://host:port
PLAYWRIGHT_PROXY=
