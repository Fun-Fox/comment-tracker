[Unit]
Description=Comment Tracker Streamlit UI
After=network.target comment-tracker.service
Requires=comment-tracker.service

[Service]
Type=simple
User=callfans
WorkingDirectory=/home/callfans/data/comment-tracker
Environment=TZ=Asia/Shanghai
Environment=API_BASE_URL=http://172.25.0.30:9000
ExecStart=/home/callfans/miniconda3/bin/conda run -n py312 streamlit run /home/callfans/data/comment-tracker/streamlit_app.py --server.port=8501 --server.address=0.0.0.0 --server.headless=true
Restart=always
RestartSec=10
StandardOutput=append:/home/callfans/data/comment-tracker/logs/streamlit.log
StandardError=append:/home/callfans/data/comment-tracker/logs/streamlit-error.log

[Install]
WantedBy=multi-user.target
